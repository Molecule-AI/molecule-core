{
  "mcpServers": {
    "awareness-memory": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@awareness-sdk/local",
        "mcp"
      ]
    },
    "molecule": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@molecule-ai/mcp-server"],
      "env": {
        "MOLECULE_URL": "http://localhost:8080"
      }
    }
  }
}
